#!/bin/bash
#
# pre-commit hook — reject any STAGED file whose basename is >= 200 BYTES.
#
# Why (TASK-85 / TASK-133): Linux ext4 caps a filename component at 255 BYTES,
# and Hebrew is 2 bytes per character. The backlog CLI embeds the full task title
# into the filename, so a long title silently produces an over-long basename; a
# 333-byte one broke actions/checkout on every workflow (CI down ~16h, 2026-06-09).
#
# Single source of truth: the byte-check lives in scripts/check_filename_length.sh,
# which the CI guard (.github/workflows/filename_guard.yml) also calls. This hook
# just feeds it the STAGED paths at the 200-byte early-warning margin (CI uses the
# 250-byte hard-cap on the whole tree). Scope: repo-wide (all staged ACMR files).
#
# Install: scripts/git_hooks/install.sh copies this into .git/hooks/pre-commit.
# Override a single commit (only if you are sure): git commit --no-verify

set -eu

repo_root="$(git rev-parse --show-toplevel)"

# Staged Added/Copied/Modified/Renamed paths, NUL-safe (names have spaces / Hebrew).
staged=()
while IFS= read -r -d '' p; do
    staged+=("$p")
done < <(git diff --cached --name-only -z --diff-filter=ACMR)

[ ${#staged[@]} -eq 0 ] && exit 0

# Delegate to the SSoT guard at the pre-commit margin (200 bytes).
FILENAME_BYTE_LIMIT=200 exec "$repo_root/scripts/check_filename_length.sh" "${staged[@]}"
